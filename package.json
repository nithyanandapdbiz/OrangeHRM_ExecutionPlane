{
  "name": "orangehrm-execution-plane",
  "version": "1.0.0",
  "description": "OrangeHRM Execution Plane — Jira + Zephyr Essential native, React web-app QA; runs inside the OrangeHRM tenant",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "pipeline": "node scripts/trigger.js",
    "e2e": "node scripts/trigger.js",
    "run": "node scripts/trigger.js",
    "test:bdd": "npx cucumber-js",
    "test:bdd:story": "npx cucumber-js tests/features/employee-login/",
    "auth:validate": "node -e \"require('dotenv').config();require('./tests/auth/authManager').ensureAuthenticated().then(t=>process.exit(t.authenticated?0:4)).catch(()=>process.exit(4))\"",
    "logs": "node scripts/tail-logs.js",
    "config:check": "node scripts/config-check.js",
    "test": "node --test test/*.test.js",
    "lint": "eslint server.js routes clients runners lib middleware test --ext .js",
    "lint:all": "eslint . --ext .js",
    "lint:fix": "eslint server.js routes clients runners lib middleware test --ext .js --fix",
    "format": "prettier --write \"{server.js,routes,clients,runners,lib,middleware,config}/**/*.js\" server.js",
    "health": "node -e \"require('http').get('http://localhost:3000/health',r=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>console.log(JSON.stringify(JSON.parse(d),null,2)))})\"",
    "discover": "node scripts/discover.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "uuid": "^10.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "11.3.0",
    "@playwright/test": "1.58.2",
    "allure-playwright": "3.6.0",
    "chart.js": "^4.5.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3"
  }
}
