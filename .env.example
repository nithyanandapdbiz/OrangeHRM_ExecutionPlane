###############################################################################
# OrangeHRM Execution Plane — Environment Configuration (authoritative)
#
# Copy to `.env` for local dev. In production, source secrets from a secret
# manager (SECRETS_PROVIDER=keyvault) — never commit real values.
#
# ⚠️  THIS FILE IS COMMITTED TO GIT — use PLACEHOLDERS ONLY. Real credentials
#     belong exclusively in `.env` (git-ignored). Never paste live tokens here.
#
# TENANT-OWNED AI (Model B): this plane is the AUTHORITATIVE owner of AI SELECTION —
# which provider/model/prompts/knowledge to use — shipped to the shared DBiz runtime
# in an immutable ExecutionContext (lib/execution-context.js). The canonical AI
# profile lives in config/ai-profile.json; env vars below may override scalars.
# CREDENTIALS ARE REFERENCES (kv://…), never raw keys — the startup guard REFUSES TO
# BOOT on any raw AI key, and the EP performs NO inference (no SDK/model calls, FF-01).
#
# Legend:  [required] must be set   [optional] has a default   [reserved] not yet
#          consumed — declared for forward compatibility.  Full reconciliation:
#          docs/CONFIGURATION.md
#
# NOTE: the EP does NOT issue JWTs (no JWT_SECRET). It obtains a SHORT-LIVED JWT via
# OAuth2 client-credentials (CLIENT_ID+CLIENT_SECRET) at the Intelligence Plane's /oauth/token.
###############################################################################

###############################################################################
# Runtime
###############################################################################
NODE_ENV=production                # [optional] production | development
PORT=3000                          # [optional] HTTP listen port
# HOST=0.0.0.0                      # [optional] bind address
PLATFORM_DIR=../OrangeHRM_AgenticQAPlatform   # [optional] Playwright/BDD suite location

###############################################################################
# Intelligence Plane (endpoint + transport only — NO AI specifics)
###############################################################################
INTELLIGENCE_API_URL=http://localhost:3001   # [required] DBiz Intelligence API base URL
INTELLIGENCE_API_VERSION=v1                   # [optional] contract version to call
INTELLIGENCE_TIMEOUT_MS=600000                # [optional] per-call timeout
INTELLIGENCE_RETRY=0                          # [optional] transient-failure retries

###############################################################################
# Tenant-owned AI selection (Model B) — canonical source: config/ai-profile.json
# These OVERRIDE the profile's scalars. REFERENCES ONLY — never a raw AI key.
###############################################################################
# AI_PROFILE_PATH=./config/ai-profile.json   # [optional] alternate profile location
# AI_PROVIDER=anthropic                        # [optional] tenant's chosen provider
# AI_MODEL=claude-sonnet-4-5-20250929          # [optional] tenant's chosen model
# AI_FALLBACK_MODEL=claude-3-5-haiku-latest    # [optional]
# AI_MAX_TOKENS=4096                           # [optional]
# AI_TEMPERATURE=0.2                           # [optional]
# AI_CREDENTIAL_REF=kv://orangehrm/ai/anthropic-prod       # [optional] REFERENCE, not a key
# PROMPT_PACK=orangehrm-hr                      # [optional] prompt-pack reference
# PROMPT_VERSION=1.0.0                         # [optional]
# KNOWLEDGE_REF=kv://orangehrm/knowledge/hr-policies       # [optional] knowledge reference

###############################################################################
# Customer / Tenant identity
###############################################################################
CUSTOMER_ID=orangehrm                         # [optional] tenant id sent to the IP

###############################################################################
# Intelligence Plane authentication — OAuth2 client-credentials (sole method)
#   The EP exchanges CLIENT_ID + CLIENT_SECRET at <INTELLIGENCE_API_URL>/oauth/token
#   for a SHORT-LIVED JWT (auto-refreshed by clients/intelligence.client.js).
#   (The legacy static CUSTOMER_JWT is DEPRECATED and no longer supported.)
###############################################################################
CLIENT_ID=your-client-id-from-dbiz            # [required] per-tenant OAuth2 client id
CLIENT_SECRET=your-client-secret-from-dbiz    # [required][secret] per-tenant client secret (dev)
# CLIENT_SECRET_REF=kv://orangehrm/oauth/client-secret     # PREFERRED in prod: a reference resolved via the secrets provider
# OAUTH_TOKEN_URL=                             # [optional] defaults to <INTELLIGENCE_API_URL>/oauth/token

###############################################################################
# Execution Plane API authentication
###############################################################################
# API_SECRET=change-me-to-a-long-random-string # [optional][secret] REQUIRED for shared/prod (guards POST /run)
# WEBHOOK_SECRET=change-me                      # [optional][secret] HMAC for inbound Jira webhooks

###############################################################################
# Secrets sourcing
###############################################################################
SECRETS_PROVIDER=env               # [optional] env | keyvault
# AZURE_KEY_VAULT_URL=https://<vault>.vault.azure.net   # [required if SECRETS_PROVIDER=keyvault]

###############################################################################
# Inter-plane transport trust (mTLS)
###############################################################################
# MTLS_CERT_PATH=/etc/certs/ep.crt   # [optional] client cert for EP→IP mTLS
# MTLS_KEY_PATH=/etc/certs/ep.key    # [optional]
# CA_CERT_PATH=/etc/certs/ca.crt     # [optional] trust anchor

###############################################################################
# Jira (issue tracker — ALM source of truth; customer tenant, never sent to DBiz)
###############################################################################
JIRA_BASE_URL=https://your-org.atlassian.net   # [required] no trailing slash
JIRA_PROJECT_KEY=OHRM                            # [required] Jira project key
JIRA_EMAIL=your-jira-account@your-org.com        # [required] Basic-auth user (email)
JIRA_API_TOKEN=your-jira-api-token-here          # [required][secret] Atlassian API token
# JIRA_API_VERSION=3                             # [optional] REST API version
# JIRA_TIMEOUT_MS=15000                          # [optional] per-request timeout

###############################################################################
# Zephyr test management (customer tenant, never sent to DBiz)
#   • Zephyr Scale : ZEPHYR_API_URL=https://api.zephyrscale.smartbear.com/v2  (Bearer token)
#   • Zephyr Squad : ZEPHYR_API_URL=https://prod-api.zephyr4jiracloud.com/v2  (per-request JWT)
###############################################################################
ZEPHYR_API_URL=https://api.zephyrscale.smartbear.com/v2   # [optional] Zephyr API base
ZEPHYR_API_TOKEN=your-zephyr-api-token-here               # [optional][secret] Zephyr token
# ZEPHYR_CYCLE_ID=                                         # [optional] pre-created cycle to reuse

###############################################################################
# Application under test — OrangeHRM (React web app; customer tenant, never sent to DBiz)
###############################################################################
APP_BASE_URL=https://opensource-demo.orangehrmlive.com   # [optional] Playwright target
APP_USERNAME=Admin                                        # [optional][secret] app login user
APP_PASSWORD=admin123                                     # [optional][secret] app login password

###############################################################################
# Playwright / Functional (BDD) execution
###############################################################################
PW_HEADLESS=false                  # [optional] true in cluster, false for local headed QA
# PLAYWRIGHT_BDD_TIMEOUT_MS=900000  # [optional] overall BDD run timeout
# CAPTURE_VIDEO=false               # [optional] record scenario video
# SESSION_MODE=shared               # [optional] shared | fresh (app auth session)
# Fine-grained tuning knobs (AUTH_*, CUCUMBER_*, PIM_*, ADMIN_*, LEAVE_*, FORM_*,
# GRID_*, CDP_*) have defaults and are catalogued in docs/CONFIGURATION.md.

###############################################################################
# Performance testing (k6) — targets/knobs only, no AI
###############################################################################
RUN_PERF=true                      # [optional] run the k6 performance stage
# PERF_BASE_URL=https://a-sanctioned-test-target
# PERF_TEST_TYPE=smoke             # smoke | load | spike
# PERF_VUS_MAX=20
# PERF_EXEC_TIMEOUT_MS=600000

###############################################################################
# Security testing (OWASP ZAP) — targets/knobs only, no AI
###############################################################################
RUN_SECURITY=true                  # [optional] run the ZAP/security stage
PENTEST_ENABLED=false              # [optional] request IP pentest advisory
# SEC_BASE_URL=https://a-sanctioned-test-target
# ZAP_AUTO_LAUNCH=false
# ZAP_PATH=/opt/zap/zap.sh
# ZAP_API_KEY=your-zap-daemon-key  # [secret] ZAP daemon key (NOT an AI key)
# ZAP_FAIL_ON=High

###############################################################################
# Pipeline target
###############################################################################
ISSUE_KEY=OHRM-1                   # [optional] default Jira issue key for `npm run e2e`

###############################################################################
# Logging
###############################################################################
LOG_LEVEL=info                     # [optional] error | warn | info | debug
LOG_DIR=logs                       # [optional] log directory
# LOG_MAX_FILES=14                  # [optional] rotation: files to keep
# LOG_MAX_SIZE_BYTES=10485760       # [optional] rotation: size per file

###############################################################################
# Observability (OpenTelemetry)  [reserved — consumed as tracing lands]
###############################################################################
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=execution-plane

###############################################################################
# Health checks
###############################################################################
# HEALTH_TIMEOUT_MS=5000            # [optional] dependency-probe timeout

###############################################################################
# Storage  [reserved — consumed as evidence externalisation lands]
###############################################################################
# REPORT_STORAGE_PATH=./reports
# ARTIFACT_STORAGE_PATH=./artifacts

###############################################################################
# Feature flags  [reserved]
###############################################################################
# FEATURE_FLAGS=                    # [optional] comma-separated flags

###############################################################################
# FORBIDDEN here (belong ONLY to DBiz_IntelligencePlane): any AI provider
# *_API_KEY, MAX_TOKENS, TEMPERATURE, TOP_P/K, *_PROMPT (raw), LLM_*, and any
# raw AI credential. Setting a raw AI key aborts boot (provider-agnostic guard).
###############################################################################
