{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "traceability-certification",
  "title": "Traceability Certification Report",
  "type": "object",
  "properties": {
    "certifiedAt":    { "type": "string", "format": "date-time" },
    "certifiedRate":  { "type": "number", "minimum": 0, "maximum": 100 },
    "brokenChains":   { "type": "integer" },
    "partialChains":  { "type": "integer" },
    "summary": {
      "type": "object",
      "properties": {
        "total":      { "type": "integer" },
        "certified":  { "type": "integer" },
        "partial":    { "type": "integer" },
        "broken":     { "type": "integer" },
        "orphanExecutions":    { "type": "integer" },
        "unverifiedMappings":  { "type": "integer" }
      }
    },
    "chains": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "scenarioName": { "type": "string" },
          "status":       { "type": "string", "enum": ["CERTIFIED", "PARTIAL", "BROKEN"] },
          "links": {
            "type": "object",
            "properties": {
              "requirement": { "type": "boolean" },
              "userStory":   { "type": "boolean" },
              "zephyrTestCase": { "type": "boolean" },
              "execution":   { "type": "boolean" },
              "evidence":    { "type": "boolean" },
              "defect":      { "type": ["boolean", "null"] }
            }
          },
          "missingLinks":  { "type": "array", "items": { "type": "string" } },
          "certScore":     { "type": "number" }
        }
      }
    }
  }
}
